{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(git pull)",
      "Bash(git push)",
      "Bash(psql * --command=SELECT*)",
      "Read(**)",
      "Edit(apps/**)",
      "Edit(packages/**)",
      "Edit(*.json)",
      "Edit(*.md)",
      "Edit(*.env.example)",
  
    "Bash(ls *)",
    "Bash(cat *)",
    "Bash(echo *)",
    "Bash(pwd)",
    "Bash(find *)",
    "Bash(grep *)",
    "Bash(head *)",
    "Bash(tail *)",
    "Bash(wc *)",

    "Bash(which *)",
    "Bash(env)",
    "Bash(printenv *)",

     "Bash(git stash *)",
    "Bash(git fetch *)",
    "Bash(git show *)",
    "Bash(git tag *)",

    "Bash(pnpm *)",
    "Bash(yarn *)",
    "Bash(pip *)",
    "Bash(pip3 *)",

    "Bash(tsc *)",
    "Bash(eslint *)",
    "Bash(prettier *)",

    "Bash(mkdir -p *)",
    "Bash(touch *)",
    "Bash(cp *)",
    "Bash(mv *)",
    "Edit(**)"   
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP *)",
      "Bash(DELETE FROM *)",
      "Bash(psql * --command=DROP*)",
      "Bash(psql * --command=DELETE*)",
      "Edit(**/migrations/**)"
    ]
  },

  "env": {
    "NODE_ENV": "development",
    "FORCE_COLOR": "1"
  },

  "attribution": {
    "commits": true,
    "pullRequests": true
  }
}
