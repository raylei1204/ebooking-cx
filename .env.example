# App environment: development | test | production
NODE_ENV=development

# Host port for the NestJS API container
API_PORT=3000

# Host port published for the PostgreSQL dev container
POSTGRES_PORT=5433

# PostgreSQL database name for the dev stack
POSTGRES_DB=freight_db

# PostgreSQL user for the dev stack
POSTGRES_USER=freight_user

# PostgreSQL password for the dev stack
POSTGRES_PASSWORD=replace_me_with_a_secure_dev_password

# PostgreSQL connection string for host-side tooling
# Dev: points to the published Podman PostgreSQL port on localhost.
# Prod: points to the VM or managed database instance.
DATABASE_URL=postgresql://freight_user:replace_me_with_a_secure_dev_password@localhost:5433/freight_db

# PostgreSQL connection string for containers inside the Podman network
DATABASE_URL_CONTAINER=postgresql://freight_user:replace_me_with_a_secure_dev_password@postgres:5432/freight_db

# JWT signing secret (min 32 chars)
JWT_SECRET=replace_me_with_a_secure_random_string_at_least_32_chars

# JWT token lifetimes
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Initial admin bootstrap seed.
# Leave unset to skip creating the bootstrap admin user.
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_NAME=Initial Admin

# Pre-generated bcrypt password hash for the bootstrap admin user.
# Replace with a secure hash generated for the environment before seeding.
AUTH_BOOTSTRAP_ADMIN_PASSWORD_HASH=$2b$12$replace_me_with_a_real_bcrypt_hash

# Optional phone number for the bootstrap admin user.
AUTH_BOOTSTRAP_ADMIN_PHONE=
